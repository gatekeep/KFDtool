<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows7.0</TargetFramework>
    <Nullable>disable</Nullable>
    <Deterministic>False</Deterministic>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <Configurations>Debug;Release</Configurations>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <PlatformTarget>x86</PlatformTarget>
    <PackageLicenseExpression>MIT-only</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/omahacommsys/KFDtool</PackageProjectUrl>
    <PackageIcon>AppIcon.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryUrl>https://github.com/omahacommsys/KFDtool</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <AssemblyVersion>1.8.8.0</AssemblyVersion>
    <FileVersion>1.8.8.0</FileVersion>
    <AssemblyInformationalVersion>1.2.0.0</AssemblyInformationalVersion>
    <Title>KFDtool</Title>
    <Version>1.8.8.0</Version>
    <Product>KFDtool</Product>
    <Copyright>Copyright 2019-2020 Ellie Dugger\nCopyright 2021-2023 Natalie Moore\nCopyright 2023-2025 Ilya Smirnov\nCopyright 2023-2024 Patrick McDonnell</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <Folder Include="Properties\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Mono.Options" Version="6.12.0.148" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\KFDEKC.Container\KFDEKC.Container.csproj" />
    <ProjectReference Include="..\KFDtool.Adapter\KFDtool.Adapter.csproj" />
    <ProjectReference Include="..\KFDtool.Elite\KFDtool.Elite.csproj" />
    <ProjectReference Include="..\KFDtool.P25\KFDtool.P25.csproj" />
    <ProjectReference Include="..\KFDtool.Shared\KFDtool.Shared.csproj" />
  </ItemGroup>

</Project>
